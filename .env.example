# Proveedor recomendado para comenzar: openai
RAG_PROVIDER=openai

# Cree una clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.6-luna
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Alternativa totalmente local (requiere Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Ajustes del recuperador
RAG_TOP_K=5
RAG_CHUNK_SIZE=1600
RAG_CHUNK_OVERLAP=250

# En OCI conviene desactivar la carga pública y hornear/montar los PDF de forma privada.
ALLOW_PDF_UPLOAD=true
